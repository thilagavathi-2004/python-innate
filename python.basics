50. Relational Operators
a = int(input("Enter first number: "))
b = int(input("Enter second number: "))

print("a == b :", a == b)
print("a != b :", a != b)
print("a > b :", a > b)
print("a < b :", a < b)
print("a >= b :", a >= b)
print("a <= b :", a <= b)

output:
Enter first number: 56
Enter second number: 78
a == b : False
a != b : True
a > b : False
a < b : True
a >= b : False
a <= b : True

