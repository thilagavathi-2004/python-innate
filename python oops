#Find common numbers in array from different class

class MCA:
    def values(self):
        return [10, 20, 30, 40]
class BCA:
    def values(self):
        return [50, 20, 30, 70]
class MSC:
    def values(self):
        return [30, 20, 90, 100]
clg = [MCA(), BCA(), MSC()]
list1= []

for obj in clg:
    list1.append(obj.values())
common = set(list1[0])

for lst in list1[1:]:
    common = common.intersection(lst)
print("common value in the lists among all class:", list(common))

#Output
common value in the lists among all class: [20, 30]

