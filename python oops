#Even numbers by using class

class EvenNumber:
    def get_numbers(self):
        self.numbers = list(map(int, input("Enter numbers separated by space:  ").split()))

    def print_even(self):
        print("Even numbers are:")
        for num in self.numbers:
            if num % 2 == 0:
                print(num, end=" ")
obj = EvenNumber()
obj.get_numbers()
obj.print_even()

#Output

Enter numbers separated by space:  25 20 15 10 5 2
Even numbers are:
