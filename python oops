# Banking Program using class

class BankAccount:
    def __init__(self, account_holder, balance=0.0):
        self.account_holder = account_holder
        self.balance = balance

    def deposit(self,amount):
        if amount>0:
            self.balance+=amount
            print(f"deposite ${amount:.2f}. New balance: ${self.balance:.2f}")
        return self.balance
    def withdraw(self,amount):
        if 0<amount <= self.balance:
            self.balance -= amount
            print(f"Withdrawn ${amount:.2f}. new balance: ${self.balance:.2f}")
        else:
            print("Inadequate Balance or invalid amount")
        return self.balance
    
class SavingsAccount(BankAccount):
    def __init__(self, account_holder, balance=0.0, interest_rate=0.02):
        self.account_holder = account_holder
        super().__init__(account_holder, balance)
        self.interest_rate = interest_rate
        
    def add_interest(self):
        interest = self.balance * self.interest_rate
        self.balance += interest
        print(f"added ${interest:.2f} interest. new balance: ${self.balance:.2f}")
        
class CheckingAccount(BankAccount):
    def __init__(self, account_holder, balance=0.0, overdraft_limit=500):
        super().__init__(account_holder, balance)
        self.overdraft_limit = overdraft_limit

    def withdraw(self, amount):
        if amount <= self.balance + self.overdraft_limit:
            self.balance -= amount
            print(f"Withdrawn ${amount:.2f} (overdraft active). new balance: $ {self.balance:.2f}")
        else:
            print("transaction declined. Overdraft Limit Exceeded")
        return self.balance

if __name__ == "__main__":
    print("=== Savings Account ===")
    s = SavingsAccount("Deva", 1000.0)
    s.deposit(500)
    s.add_interest()

    print("\n=== Checking Account ===")
    c = CheckingAccount("Bala", 100.0)
    c.deposit(500)
    c.withdraw(500)

#Output

=== Savings Account ===
deposite $500.00. New balance: $1500.00
added $30.00 interest. new balance: $1530.00

=== Checking Account ===
deposite $500.00. New balance: $600.00
Withdrawn $500.00 (overdraft active). new balance: $ 100.00

