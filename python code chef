17. Spoon in Matrix

t = int(input())

for _ in range(t):
    r, c = map(int, input().split())

    matrix = []
    found = False

    for _ in range(r):
        matrix.append(input().lower())

    # Check rows
    for row in matrix:
        if "spoon" in row:
            found = True
            break

    # Check columns if not found in rows
    if not found:
        for col in range(c):
            column = ""
            for row in range(r):
                column += matrix[row][col]

            if "spoon" in column:
                found = True
                break

    if found:
        print("There is a spoon!")
    else:
        print("There is indeed no spoon!")

