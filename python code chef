11. Group Assignment - GRPASSN

t = int(input())

while t > 0:
    n = int(input())
    p = list(map(int, input().split()))

    freq = {}

    for x in p:
        freq[x] = freq.get(x, 0) + 1

    possible = True

    for k in freq:
        if freq[k] % k != 0:
            possible = False
            break

    if possible:
        print("YES")
    else:
