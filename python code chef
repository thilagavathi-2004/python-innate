25. No Winner

t = int(input())

for _ in range(t):
    A, B, C, M = map(int, input().split())

    possible = False

    for x in range(M + 1):
        for y in range(M - x + 1):
            z = M - x - y

            a = A + x
            b = B + y
            c = C + z

            if a == b or b == c or a == c:
                possible = True
                break

        if possible:
            break

    print("YES" if possible else "NO")

