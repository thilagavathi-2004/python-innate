12. Sugar Limit - SULIM

t = int(input())

while t > 0:
    n = int(input())
    a = list(map(int, input().split()))
    b = list(map(int, input().split()))

    ans = 0

    for L in range(101):
        total = 0

        for i in range(n):
            if b[i] <= L and a[i] > 0:
                total += a[i]

        ans = max(ans, total - L)

    print(ans)
    t -= 1

